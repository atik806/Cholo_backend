{
  "version": 2,
  "installCommand": "npm install && npm run build",
  "buildCommand": null,
  "functions": {
    "api/index.ts": {
      "includePaths": ["dist/**", "node_modules/**"]
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
